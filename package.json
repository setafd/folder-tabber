{
  "name": "folder-tabber",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "steiger": "steiger ./src",
    "gen:dependency-cruiser": "npx depcruise src --include-only \"^src\" --output-type dot | dot -T svg > dependency-graph.svg",
    "prepare": "husky",
    "knip": "knip"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "packery": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.1",
    "react-responsive-modal": "^7.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12",
    "zustand-sync-tabs": "^0.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@feature-sliced/steiger-plugin": "^0.5.7",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/chrome": "^0.0.322",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "knip": "^6.4.1",
    "prettier": "^3.8.1",
    "sass": "^1.99.0",
    "sass-embedded": "^1.99.0",
    "steiger": "^0.5.11",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.4.2",
    "vite-plugin-static-copy": "^3.4.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
